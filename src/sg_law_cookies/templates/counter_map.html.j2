{% extends "base.html.j2" %}
{#- The counter map — PRD §7 constellation, ported from the approved mockup
    mockups/h-counter-map.html. Deltas from the mockup, deliberate:
    1. Data is fetched from /data/sky/index.json + /data/sky/<date>.json
       (sitegen emits them), not inlined; an in-page cache avoids refetches.
    2. D3 is vendored at /static/d3.v7.min.js — no CDN.
    3. Page CSS lives in /static/sky.css on top of the site.css tokens.
    4. ALL page JS lives in /static/sky.js (deferred) — no inline scripts.
    5. The scrubber shows AT MOST the most recent 14 days; older days will
       become reachable via the archive in a later phase.
    6. Empty index → "the counter is bare" graceful state.
    Phase 6 adds Levels 2–3 (PRD §7.2–7.3, §7.7): focus mode fans an area's
    cookies out as typed nodes (round disc = news, hexagon = judgment,
    pineapple-tart styling = high significance) with chocolate-chip dots for
    shared FOLIO concepts; #focus-list is the ≤720px list degradation; the
    #panel dialog is the Level-3 cookie detail (right card / bottom sheet),
    deep-linked via #<date> and #<date>/<cookieid>. -#}

{% block title %}SG Law Cookies — the counter map{% endblock %}

{% block head %}
<link rel="stylesheet" href="/static/sky.css">
<script src="/static/d3.v7.min.js"></script>
<script src="/static/sky.js" defer></script>
{% endblock %}

{% block content %}
<section class="counter-map">
  <div class="skyhead">
    <p class="kick">The counter map</p>
    <h1>The spread on <em id="dayname">the day</em></h1>
    <p class="sub">every area of law, pressed as <a class="kuih" href="https://en.wikipedia.org/wiki/Kue_bangkit" target="_blank" rel="noopener">kuih bangkit</a> and sized by the day's bake — a red dot where it's still warm</p>
    <p id="stats"></p>
  </div>

  <svg id="sky" viewBox="0 0 1000 560">
    <defs>
      <radialGradient id="dough" cx="36%" cy="30%"><stop offset="30%" stop-color="#E9C887"/><stop offset="100%" stop-color="#D4A356"/></radialGradient>
      <radialGradient id="bangkit" cx="42%" cy="36%"><stop offset="25%" stop-color="#FEFCF5"/><stop offset="78%" stop-color="#F8F2DF"/><stop offset="100%" stop-color="#EDE3C8"/></radialGradient>
      <radialGradient id="tart" cx="42%" cy="34%"><stop offset="35%" stop-color="#F2B348"/><stop offset="100%" stop-color="#D98A12"/></radialGradient>
      <filter id="soft" x="-40%" y="-40%" width="180%" height="180%"><feDropShadow dx="0" dy="4" stdDeviation="5" flood-color="#14201F" flood-opacity="0.25"/></filter>
    </defs>
  </svg>
  <p id="sky-empty" class="sky-empty" hidden>the counter is bare — nothing has come out of the oven yet.</p>

  <div class="scrub" id="scrub"></div>

  {#- ≤720px Level-2 degradation: focus mode renders the area's cookies as a
      stacked price-card list here instead of spatial nodes (PRD §7.7). -#}
  <div id="focus-list" class="focus-list" hidden></div>

  <p class="legend"><a class="kuih" href="https://en.wikipedia.org/wiki/Kue_bangkit" target="_blank" rel="noopener">kuih bangkit</a> = area of law · size = the day's bake · <span class="t">red dot</span> = still warm · <span class="o">ochre threads</span> = shared doctrine this week</p>
</section>

<div id="tip"></div>

{#- Level 3 — cookie detail panel. Desktop: right-side parchment card with a
    price-card-style header; mobile: bottom sheet. sky.js fills it in. -#}
<div id="panel-backdrop" hidden></div>
<aside id="panel" class="cookie-panel" role="dialog" aria-modal="true" aria-labelledby="panel-headline" hidden>
  <header class="panel-tag">
    <span id="panel-meta"></span>
    <button id="panel-close" type="button" aria-label="Close cookie detail">×</button>
  </header>
  <div class="panel-body">
    <h2 id="panel-headline"></h2>
    <p id="panel-summary" class="panel-summary"></p>
    <p id="panel-why" class="panel-why" hidden><b>Why it matters</b><span></span></p>
    <div id="panel-issues" class="panel-issues" hidden>
      <h3>What the court decided</h3>
      <div class="issues"></div>
    </div>
    <div id="panel-concepts" class="panel-concepts" hidden></div>
    <a id="panel-source" class="panel-go" target="_blank" rel="noopener" hidden></a>
  </div>
</aside>
{% endblock %}
