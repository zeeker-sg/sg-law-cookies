{% extends "base.html.j2" %}
{# Archive: plain dot-leader list of baking days, reusing the menu styles. #}

{% block title %}Archive — SG Law Cookies{% endblock %}

{% block content %}
  <section class="menu e2">
    <div class="menu-head">
      <h3>The Archive</h3>
      <p>every baking day on record — day-old cookies keep</p>
    </div>
    {% if days %}
    <div class="menu-cols">
      <div class="menu-sec">
        {% for d in days %}
        <a class="mi" href="/daily/{{ d.date }}/">
          <span class="g">○</span><span class="h">{{ d.date_long }}</span><span class="dots"></span><span class="src">{{ d.total }} COOKIE{{ 'S' if d.total != 1 }}{% if d.high %} · {{ d.high }} TART{{ 'S' if d.high != 1 }}{% endif %}</span>
        </a>
        {% endfor %}
      </div>
    </div>
    {% else %}
    <p class="case-note">No baking days on record yet — the oven's warming up.</p>
    {% endif %}
  </section>
{% endblock %}
